    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//UPDATE VALUES&#xD;&#xA;String stage = &quot;SRC&quot;; //SRC or TGT&#xD;&#xA;String entity = &quot;legacy_install&quot;; //Input Name&#xD;&#xA;&#xD;&#xA;StringBuilder sbData = new StringBuilder();&#xD;&#xA;StringBuilder sbCols = new StringBuilder(); // &lt;-- Added to collect column names&#xD;&#xA;//Get all fields belonging to the incoming row structure&#xD;&#xA;java.lang.reflect.Field[] fields = reject_install.getClass().getDeclaredFields();&#xD;&#xA;&#xD;&#xA;boolean isFirstField = true;&#xD;&#xA;&#xD;&#xA;for (java.lang.reflect.Field field : fields) {&#xD;&#xA;String fieldName = field.getName();&#xD;&#xA;&#xD;&#xA;// 1. SKIP TALEND SYSTEM FIELDS (Prevents internal object hash values)&#xD;&#xA;if (fieldName.equals(&quot;hashCode&quot;) || &#xD;&#xA;   fieldName.equals(&quot;hashCodeDirty&quot;) || &#xD;&#xA;   fieldName.equals(&quot;loopKey&quot;) || &#xD;&#xA;   fieldName.equals(&quot;errorCode&quot;) || &#xD;&#xA;   fieldName.equals(&quot;errorMessage&quot;) || &#xD;&#xA;   fieldName.startsWith(&quot;checkNulls&quot;) ||&#xD;&#xA;   fieldName.startsWith(&quot;_&quot;) || &#xD;&#xA;   java.lang.reflect.Modifier.isStatic(field.getModifiers())) {&#xD;&#xA;   continue; &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;try {&#xD;&#xA;   field.setAccessible(true);&#xD;&#xA;   Object value = field.get(reject_install); // Extract the actual field data&#xD;&#xA;   &#xD;&#xA;   String cleanValue = &quot;&quot;;&#xD;&#xA;   &#xD;&#xA;   if (value != null) {&#xD;&#xA;       // 2. FIX FOR BYTE ARRAYS (Converts binary data to normal text instead of [B@hash)&#xD;&#xA;       if (value instanceof byte[]) {&#xD;&#xA;           cleanValue = new String((byte[]) value, &quot;UTF-8&quot;);&#xD;&#xA;       } &#xD;&#xA;       // 3. FIX FOR ARRAYS (Converts lists/arrays to standard readable strings)&#xD;&#xA;       else if (value.getClass().isArray()) {&#xD;&#xA;           cleanValue = java.util.Arrays.deepToString((Object[]) value);&#xD;&#xA;       } &#xD;&#xA;       // 4. STANDARD CONVERSION (For Strings, Integers, Dates, Decimals, etc.)&#xD;&#xA;       else {&#xD;&#xA;           cleanValue = value.toString();&#xD;&#xA;       }&#xD;&#xA;   }&#xD;&#xA;   &#xD;&#xA;   // Append pipe delimiter between column values and names&#xD;&#xA;   if (!isFirstField) {&#xD;&#xA;       sbData.append(&quot;|&quot;); &#xD;&#xA;       sbCols.append(&quot;|&quot;); // &lt;-- Added delimiter for column headers&#xD;&#xA;   }&#xD;&#xA;   &#xD;&#xA;   sbData.append(cleanValue);&#xD;&#xA;   sbCols.append(fieldName); // &lt;-- Added to track current column name&#xD;&#xA;   isFirstField = false;&#xD;&#xA;   &#xD;&#xA;} catch (Exception e) {&#xD;&#xA;   // Fail-safe: if a column can't be read, add an empty placeholder to preserve structure&#xD;&#xA;   if (!isFirstField) {&#xD;&#xA;       sbData.append(&quot;|&quot;);&#xD;&#xA;       sbCols.append(&quot;|&quot;);&#xD;&#xA;   }&#xD;&#xA;   sbData.append(&quot;&quot;);&#xD;&#xA;   sbCols.append(fieldName);&#xD;&#xA;   isFirstField = false;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//Pass the fully concatenated string to the output component row&#xD;&#xA;install_reject.REJECT_ID = java.util.UUID.randomUUID().toString();&#xD;&#xA;install_reject.PROJECT_NAME = projectName;&#xD;&#xA;install_reject.JOB_NAME = jobName;&#xD;&#xA;install_reject.EXECUTION_ID = pid;&#xD;&#xA;install_reject.JOB_START_TIME = null; // Tip: Map your job start context variable here if available&#xD;&#xA;install_reject.STAGE = stage;&#xD;&#xA;install_reject.ENTITY_NAME = entity;&#xD;&#xA;install_reject.ENTITY_COLUMN = sbCols.toString(); // &lt;-- Maps the structured headers to the schema&#xD;&#xA;install_reject.ERROR_MESSAGE = reject_install.errorMessage;&#xD;&#xA;install_reject.REJECTED_DATA = sbData.toString();&#xD;&#xA;install_reject.REJECTED_ON = TalendDate.getCurrentDate();&#xD;&#xA;install_reject.STEWARD_STATUS = &quot;NEW&quot;;"/>
