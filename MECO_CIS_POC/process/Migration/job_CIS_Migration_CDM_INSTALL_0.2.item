&#xA;       } &#xD;&#xA;       // 4. STANDARD CONVERSION (For Strings, Integers, Dates, Decimals, etc.)&#xD;&#xA;       else {&#xD;&#xA;           cleanValue = value.toString();&#xD;&#xA;       }&#xD;&#xA;   }&#xD;&#xA;   &#xD;&#xA;   // Append pipe delimiter between column values and names&#xD;&#xA;   if (!isFirstField) {&#xD;&#xA;       sbData.append(&quot;|&quot;); &#xD;&#xA;       sbCols.append(&quot;|&quot;); // &lt;-- Added delimiter for column headers&#xD;&#xA;   }&#xD;&#xA;   &#xD;&#xA;   sbData.append(cleanValue);&#xD;&#xA;   sbCols.append(fieldName); // &lt;-- Added to track current column name&#xD;&#xA;   isFirstField = false;&#xD;&#xA;   &#xD;&#xA;} catch (Exception e) {&#xD;&#xA;   // Fail-safe: if a column can't be read, add an empty placeholder to preserve structure&#xD;&#xA;   if (!isFirstField) {&#xD;&#xA;       sbData.append(&quot;|&quot;);&#xD;&#xA;       sbCols.append(&quot;|&quot;);&#xD;&#xA;   }&#xD;&#xA;   sbData.append(&quot;&quot;);&#xD;&#xA;   sbCols.append(fieldName);&#xD;&#xA;   isFirstField = false;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//Pass the fully concatenated string to the output component row&#xD;&#xA;install_reject.REJECT_ID = java.util.UUID.randomUUID().toString();&#xD;&#xA;install_reject.PROJECT_NAME = projectName;&#xD;&#xA;install_reject.JOB_NAME = jobName;&#xD;&#xA;install_reject.EXECUTION_ID = pid;&#xD;&#xA;install_reject.JOB_START_TIME = null; // Tip: Map your job start context variable here if available&#xD;&#xA;install_reject.STAGE = stage;&#xD;&#xA;install_reject.ENTITY_NAME = entity;&#xD;&#xA;install_reject.ENTITY_COLUMN = sbCols.toString(); // &lt;-- Maps the structured headers to the schema&#xD;&#xA;install_reject.ERROR_MESSAGE = reject_install.errorMessage;&#xD;&#xA;install_reject.REJECTED_DATA = sbData.toString();&#xD;&#xA;install_reject.REJECTED_ON = TalendDate.getCurrentDate();&#xD;&#xA;install_reject.STEWARD_STATUS = &quot;NEW&quot;;"/>
