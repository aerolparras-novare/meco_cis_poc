    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="context.dt_ops_job_end_time = TalendDate.getCurrentDate();&#xD;&#xA;&#xD;&#xA;long durationMs = TalendDate.diffDate(context.dt_ops_job_end_time, context.dt_ops_job_start_time, &quot;SSS&quot;);&#xD;&#xA;System.out.println(&quot;[TALEND CORE] Job terminated gracefully. Total execution duration: &quot; + durationMs + &quot; ms.&quot;);"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="terminate_job"/>
