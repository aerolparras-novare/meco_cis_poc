  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="360" posY="80" sizeX="121" sizeY="40">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//Capture exact system startup millisecond&#xD;&#xA;context.dt_ops_job_start_time = TalendDate.getCurrentDate();&#xD;&#xA;&#xD;&#xA;//Dynamically log execution status to the console log trace&#xD;&#xA;System.out.println(&quot;[TALEND CORE] Job initialized: &quot; + jobName + &#xD;&#xA;                &quot; | PID: &quot; + pid + &#xD;&#xA;                &quot; | Start Time: &quot; + TalendDate.formatDate(&quot;yyyy-MM-dd HH:mm:ss&quot;, context.dt_ops_job_start_time));"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="initialize_param"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
