  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="959" posY="120" sizeX="121" sizeY="40">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_2" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="String currentFile = (String)globalMap.get(&quot;tFileList_1_CURRENT_FILE&quot;);&#xD;&#xA;java.util.Set&lt;String> checklist = (java.util.Set&lt;String>)globalMap.get(&quot;fileChecklist&quot;);&#xD;&#xA;&#xD;&#xA;String matchedMask = null;&#xD;&#xA;&#xD;&#xA;// Loop through our checklist to see which mask matches the file&#xD;&#xA;for (String mask : checklist) {&#xD;&#xA;    // Inject (?i) at the beginning of the evaluation string&#xD;&#xA;    String regex = &quot;(?i)^&quot; + mask.replace(&quot;.&quot;, &quot;\\.&quot;).replace(&quot;*&quot;, &quot;.*&quot;) + &quot;$&quot;;&#xD;&#xA;    &#xD;&#xA;    if (currentFile.matches(regex)) {&#xD;&#xA;        matchedMask = mask;&#xD;&#xA;        break;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// If a match is found, remove it from the checklist&#xD;&#xA;if (matchedMask != null) {&#xD;&#xA;    checklist.remove(matchedMask);&#xD;&#xA;    System.out.println(&quot;Successfully processed and verified: &quot; + currentFile);&#xD;&#xA;}"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="crossOff_checklist"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_2"/>
  </node>
