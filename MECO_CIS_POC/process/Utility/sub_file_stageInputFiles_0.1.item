    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//Create a thread-safe concurrent set&#xD;&#xA;java.util.Set&lt;String> checklist = java.util.concurrent.ConcurrentHashMap.newKeySet();&#xD;&#xA;&#xD;&#xA;//Split your newline context parameter&#xD;&#xA;for (String line : context.file_stg_source_mask_list.split(&quot;\\r?\\n&quot;)) {&#xD;&#xA; if (!line.trim().isEmpty()) {&#xD;&#xA;     checklist.add(line.trim());&#xD;&#xA; }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Save this thread-safe checklist globally&#xD;&#xA;globalMap.put(&quot;fileChecklist&quot;, checklist);&#xD;&#xA;System.out.println(&quot;Parallel Verification active. Expecting &quot; + checklist.size() + &quot; pattern(s).&quot;);"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="initialize_checklist"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
