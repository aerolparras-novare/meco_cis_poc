      <elementValue elementRef="VALUE" value="TalendDate.formatDate(&quot;yyyy-MM-dd HH:mm:ss&quot;, TalendDate.getCurrentDate())" id="9"/>
    </elementParameter>
    <elementParameter field="TEXT" name="LABEL" value="setGlobalVar"/>
