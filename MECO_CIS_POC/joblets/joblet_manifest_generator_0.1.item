      <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;INSERT INTO TABLE `&quot;+context.audit_database+&quot;`.`&quot;+context.manifest_table+&quot;` (&#xD;&#xA;    ingest_date,&#xD;&#xA;    source_system,&#xD;&#xA;    source_schema,&#xD;&#xA;    tablename,&#xD;&#xA;    target_schema,&#xD;&#xA;    processing_start_time,&#xD;&#xA;    processing_end_time,&#xD;&#xA;    source_count,&#xD;&#xA;    target_count&#xD;&#xA;)&#xD;&#xA;VALUES (&#xD;&#xA;    '&quot;+(String) globalMap.get(&quot;ingest_date&quot;)+&quot;',&#xD;&#xA;    '&quot;+(String) globalMap.get(&quot;source_system&quot;)+&quot;',&#xD;&#xA;    '&quot;+context.source_schema+&quot;',&#xD;&#xA;    '&quot;+context.target_tablename+&quot;',&#xD;&#xA;    '&quot;+context.target_schema+&quot;',&#xD;&#xA;     '&quot;+(String) globalMap.get(&quot;processing_start_time&quot;)+&quot;',&#xD;&#xA;    FROM_UNIXTIME(UNIX_TIMESTAMP(),'yyyy-MM-dd HH:mm:ss'),&#xD;&#xA;     &quot;+context.source_count+&quot;,&#xD;&#xA;     &quot;+context.target_count+&quot;&#xD;&#xA;)&#xD;&#xA;&quot;"/>
      <elementParameter field="CHECK" name="DIE_ON_ERROR" value="true"/>
