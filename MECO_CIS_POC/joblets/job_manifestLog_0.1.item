    <node componentName="tJavaFlex" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="320" posY="240" sizeX="121" sizeY="40">
      <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaFlex_2" show="false"/>
      <elementParameter field="CHECK" name="DATA_AUTO_PROPAGATE" value="true"/>
      <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_START" value="//Initialize the context mapping exactly like before&#xD;&#xA;java.util.Map&lt;String, String> componentLabels = new java.util.HashMap&lt;>();&#xD;&#xA;if (context.map_componentLabel != null &amp;&amp; !context.map_componentLabel.trim().isEmpty()) {&#xD;&#xA; String[] pairs = context.map_componentLabel.split(&quot;\\r?\\n&quot;);&#xD;&#xA; for (String pair : pairs) {&#xD;&#xA;     if (pair.trim().isEmpty()) continue;&#xD;&#xA;     String[] keyValue = pair.split(&quot;:&quot;);&#xD;&#xA;     if (keyValue.length == 2) {&#xD;&#xA;         componentLabels.put(keyValue[0].trim(), keyValue[1].trim());&#xD;&#xA;     }&#xD;&#xA; }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Start looping through Talend's memory&#xD;&#xA;for (java.util.Map.Entry&lt;String, Object> entry : globalMap.entrySet()) {&#xD;&#xA; String key = entry.getKey();&#xD;&#xA; if (key.contains(&quot;_NB_LINE&quot;)) {&#xD;&#xA;     String uniqueName = key.split(&quot;_NB_LINE&quot;)[0];&#xD;&#xA;     String labelName = componentLabels.get(uniqueName);&#xD;&#xA;     &#xD;&#xA;     // If it's not in our context mapping, we skip it to keep audit clean&#xD;&#xA;     if (labelName == null) continue; &#xD;&#xA;     &#xD;&#xA;     long count = Long.parseLong(String.valueOf(entry.getValue()));&#xD;&#xA;     String compType = uniqueName.contains(&quot;Input&quot;) ? &quot;INPUT&quot; : &quot;OUTPUT&quot;;"/>
      <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_MAIN" value="//'row2' is the name of the output link connecting tJavaFlex to tDBOutput&#xD;&#xA;row9.job_name = jobName;&#xD;&#xA;row9.run_id = pid;&#xD;&#xA;row9.environment = context.str_ops_execution_env; // Assuming you have an env variable&#xD;&#xA;row9.component_name = uniqueName;&#xD;&#xA;row9.component_lable = labelName;&#xD;&#xA;row9.component_type = compType;&#xD;&#xA;row9.record_count = count;&#xD;&#xA;row9.run_status = &quot;SUCCESS&quot;;&#xD;&#xA;row9.created_at = java.util.Calendar.getInstance().getTime();"/>
      <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_END" value=" }&#xD;&#xA; }"/>
      <elementParameter field="CHECK" name="Version_V2_0" value="false" show="false"/>
      <elementParameter field="CHECK" name="Version_V3_2" value="false" show="false"/>
      <elementParameter field="CHECK" name="Version_V4.0" value="true" show="false"/>
      <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
      <elementParameter field="TEXT" name="LABEL" value="java_reconciliation"/>
      <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
